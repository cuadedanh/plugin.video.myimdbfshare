<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.myimdbfshare"
       name="My Fshare Finder and play"
       version="2.4.0"
       provider-name="cuadedanh@gmail.com">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
     <import addon="script.module.requests"/>
  </requires>
  <extension point="xbmc.python.pluginsource"
             library="default.py">
        <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Find and Play Fshare links với đủ thông tin meta, trakt, làm player search tìm link fshare cho tmdb helper </summary>
    <description lang="en">This addon allows you to find, play download Fshare.vn links. Fshare search for tmdb helper players </description>
    <platform>all</platform>
    <license>GPL-2.0-only</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
  </extension>
</addon>
